
namespace async;

class Task norfc {
	funcref (Task) void handler_func;
	ptr func;
	ptr args = 0;
	ptr result = 0;
	bool ready = false;
	bool suspended = false;
	bool executed = false;
	i32 nr = 0;
	?Task next = null;

	//public func __free(){
	//	io:print("free-task\n");
	//}

	public func continue (){
		Taskman.add_task(this);
	}

	public func waitForSuspendStatus (bool status){
        while(true){
			if(this.suspended == status){
				break;
			}
            main:main:usleep(1);
		}
	}
}
