
namespace async;

#header "sys/thread"

class Mutex norfc {

	public main:main:pthread_mutex_t mutex;

	static func make() Mutex {
		@ pm = mem:alloc_flat(sizeof(main:main:pthread_mutex_t));
		@ check = main:main:pthread_mutex_init(pm, null);
		Mutex m = mem:alloc_flat(sizeof(Mutex));
		m.mutex = pm;
		return m;
	}

	func lock() {
		mutex_lock getptrv this.mutex as NPT main:main:pthread_mutex_t;
	}

	func unlock() {
		mutex_unlock getptrv this.mutex as NPT main:main:pthread_mutex_t;
	}
}
