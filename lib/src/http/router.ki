
namespace http;

class RouteEntry{
	public Route route = null;
	public type:Map<Route> routes;
}

class RouteArg{
	public i32 i;
	public String name;
}

class Router{

	private RouteEntry tree;

	public func add(String method, String url, funcref (Request) Response handler) {
		if(url.length == 0 || url.char(0) != '/'){
			io:println("Invalid route: ");
			exit 1;
		}

		@ url_tmp = url.substring(1, url.length - 1);
		@ parts = url_tmp.split("/");
		parts.remove(0);

		@ ref = this.tree;
	}
}