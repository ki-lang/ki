
namespace http;

class Response {
	public u32 status = 200;
	public string body;

	public func output() string {
		@ data = "";

		data.__add("HTTP/1.1 200 OK\r\nContent-type: text/plain; charset=utf-8\r\nContent-Length:");
		data.__add(this.body.str());
		data.__add("\r\n\r\n");
		data.__add(this.body);

		return data;
	}

	public func __free(){
		this.body.__free();
		@ a = allocator sizeof(Response);
		a.free(this);
	}
}
