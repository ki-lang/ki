
namespace http;

class Response {
	public u32 status = 200;
	public string body;

	public func output() string {
		return "HTTP/1.1 200 OK\r\nContent-type: text/html\r\nConnection: close\r\nContent-length:11\r\n\r\nHello world";
	}

	public func __free(){
		this.body.__free();
		@ a = allocator sizeof(Response);
		a.free(this);
	}
}
