	public func to_string() type:string {
		ki:type:cstring x = this.to_cstring();
		string res = x.to_string();
		ki:mem:free(x);
		return res;
	}

	public func to_cstring() type:cstring {
		ptr str = mem:alloc(20);
		ptr strp = str;

		@ value = this;
		@ rest = 0;
		u8 pos = sizeof(this) - 1;
		u8 len = 0;
		uxx mult = 1;

		while(true){
			rest = value % (mult * 10);
			value -= rest;
			uxx r = rest / mult;
			u8 b = cast r as u8;
			b += 48; // ascii

			setptrv strp to b;
			strp++;

			if(value == 0){ break; }

			mult = mult * 10;
			pos--;
			len++;
		}

		setptrv strp to '\0';
		ptr result = mem:alloc(20);
		ptr tmp = result;
		while(len >= 0){
			strp = str;
			strp += len;
			u8 x = getptrv strp as u8;
			len--;
			setptrv result to x;
			result++;
		}
		setptrv result to '\0';

		ki:mem:free(str);

		result = tmp;
		@ r = cast result as type:cstring;

		return r;
	}
}
