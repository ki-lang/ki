
namespace type;

class u32 number:u:4 {
	
	trait type_trait:Number;

	public func byte_swap() u32 {
		@ bytes = sizeof(u32);
		u32 result = 0;
		ptr adr = (getptr this) + bytes - 1;
		ptr to_adr = getptr result;
		@ c = 0;
		while(c < bytes){
			u8 ch = getptrv adr as u8;
			setptrv to_adr to ch;
			adr--;
			to_adr++;
			c++;
		}
		return result;
	}
	
}
